# ============================================================
# QUANTARA — Variables d'environnement Backend
# Copier ce fichier en .env.local et remplir les valeurs.
# NE PAS committer .env.local dans git.
# ============================================================

# -- Supabase (auto-injectées dans les Edge Functions) --------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# -- API-Football ---------------------------------------------
# Obtenir sur : https://www.api-football.com/
API_FOOTBALL_KEY=your_api_football_key

# -- CinetPay -------------------------------------------------
# Dashboard : https://cinetpay.com/
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_cinetpay_site_id
CINETPAY_SECRET=your_cinetpay_webhook_secret

# -- OpenAI ---------------------------------------------------
# Optionnel : génération de l'analyse textuelle des pronos
# https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# -- Firebase Cloud Messaging (notifications push) -----------
# Obtenir dans Firebase Console > Project Settings > Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key
